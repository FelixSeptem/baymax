# Updated on 2026-03-23 from refreshed local stable samples of BenchmarkMultiAgentMainline*
# (benchtime=200ms, count=5; multiple runs; use central tendency to reduce transient noise)
BAYMAX_MULTI_AGENT_BENCH_ENABLED=true
BAYMAX_MULTI_AGENT_BENCH_BENCHTIME=200ms
BAYMAX_MULTI_AGENT_BENCH_COUNT=5

# Default degradation thresholds (percent)
BAYMAX_MULTI_AGENT_BENCH_MAX_NS_DEGRADATION_PCT=8
BAYMAX_MULTI_AGENT_BENCH_MAX_P95_DEGRADATION_PCT=12
BAYMAX_MULTI_AGENT_BENCH_MAX_ALLOCS_DEGRADATION_PCT=10

# Baseline: synchronous invocation path
BAYMAX_MULTI_AGENT_BENCH_BASELINE_SYNC_NS_OP=5600000
BAYMAX_MULTI_AGENT_BENCH_BASELINE_SYNC_P95_NS_OP=6150000
BAYMAX_MULTI_AGENT_BENCH_BASELINE_SYNC_ALLOCS_OP=121

# Baseline: async reporting path
BAYMAX_MULTI_AGENT_BENCH_BASELINE_ASYNC_NS_OP=15000000
BAYMAX_MULTI_AGENT_BENCH_BASELINE_ASYNC_P95_NS_OP=21200000
BAYMAX_MULTI_AGENT_BENCH_BASELINE_ASYNC_ALLOCS_OP=72

# Baseline: delayed dispatch path
BAYMAX_MULTI_AGENT_BENCH_BASELINE_DELAYED_NS_OP=600000
BAYMAX_MULTI_AGENT_BENCH_BASELINE_DELAYED_P95_NS_OP=1020000
BAYMAX_MULTI_AGENT_BENCH_BASELINE_DELAYED_ALLOCS_OP=41

# Baseline: recovery replay path
BAYMAX_MULTI_AGENT_BENCH_BASELINE_RECOVERY_NS_OP=9000
BAYMAX_MULTI_AGENT_BENCH_BASELINE_RECOVERY_P95_NS_OP=9000
BAYMAX_MULTI_AGENT_BENCH_BASELINE_RECOVERY_ALLOCS_OP=28
