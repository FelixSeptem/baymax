# Updated on 2026-04-08 from A64 gate pipeline timing observations.
# Governance policy: env > baseline file > script default.
# This file defines shared defaults for both shell and PowerShell gate-latency checks.

# Per-step and total latency budgets (seconds).
BAYMAX_A64_GATE_LATENCY_MAX_STEP_SECONDS=600
BAYMAX_A64_GATE_LATENCY_MAX_TOTAL_SECONDS=1200

# Optional report output path. Keep empty by default; set in CI/PR job when artifacts are required.
# BAYMAX_A64_GATE_LATENCY_REPORT_PATH=.artifacts/a64/gate-latency-budget-report.json
