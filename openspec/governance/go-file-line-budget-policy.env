# A63 single-file Go line-budget policy (non-openspec scope)
# Statistics and enforcement should use tracked files from:
# a2a adapter cmd context core docs examples integration mcp memory model
# observability orchestration runtime scripts skill tool + repo root docs.

BAYMAX_GO_LINE_BUDGET_WARN=800
BAYMAX_GO_LINE_BUDGET_HARD=1200

# Only openspec/** is exempt from A63 code-size governance.
BAYMAX_GO_LINE_BUDGET_EXCLUDED_PREFIX=openspec/

# Exception rows are defined in:
# openspec/governance/go-file-line-budget-exceptions.csv
# format: path,owner,reason,expiry,baseline_lines,allow_growth
